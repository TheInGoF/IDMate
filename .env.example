# .env.example — copy to .env and fill in real values.
# .env is gitignored and never committed.

# ── InfluxDB ──────────────────────────────────────────────────
INFLUX_PORT=3001
INFLUX_USER=admin
INFLUX_PASS=change-me
INFLUX_ORG=home
INFLUX_BUCKET=can-scan
INFLUX_TOKEN=change-me-to-a-long-random-token
INFLUX_DEVICE=id7

# ── Triplog (trip log) ───────────────────────────────────────
TRIPLOG_PORT=3004
# Session secret. If empty, auto-generated and stored in the SQLite DB.
# Recommended: openssl rand -hex 32
SECRET_KEY=
# Note: on first start the app has no users. The setup wizard at /setup
# will create the admin account interactively (username + password + 2FA).

# ── Language ────────────────────────────────────────────────
# DE = Deutsch, EN = English (also switchable in the UI settings)
LANGUAGE=DE

# ── MQTT (Mosquitto) ─────────────────────────────────────────
MQTT_PORT=3005
MQTT_DOMAIN=localhost
MQTT_DATA_TOPIC=tele/+/data
# AES-256 key (32 bytes, hex). Generate with: openssl rand -hex 32
# MUST match the key used in the ESP firmware. Never use a default value.
MQTT_AES_KEY=
# TLS to the broker (0 = off, 1 = on)
MQTT_TLS=0

# ── Charge tracker (Home Assistant webhook) ──────────────────
# Optional bearer token for the HA automation (empty = no auth required).
# Webhook URL: http://<TRIPLOG_HOST>:<TRIPLOG_PORT>/api/charge/reading
# Internal example: http://192.168.x.y:3004/api/charge/reading
CHARGE_WEBHOOK_TOKEN=

# ── Debug (optional) ─────────────────────────────────────────
# 1 = debug routes enabled (/debug, /scan-debug, /influx-delete), 0 = off
ENABLE_DEBUG=1
